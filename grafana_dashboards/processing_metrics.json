{
  "dashboard": {
    "title": "Financial Data Processor - Processing Metrics",
    "tags": ["finance", "processing", "metrics"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "File Upload Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(file_uploads_total[5m])",
            "legendFormat": "{{source}} - {{file_type}} - {{status}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Processing Duration (p95)",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(processing_duration_seconds_bucket[5m]))",
            "legendFormat": "{{source}} - {{operation}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
      },
      {
        "id": 3,
        "title": "Processing Errors Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(processing_errors_total[5m])",
            "legendFormat": "{{source}} - {{error_type}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}
      },
      {
        "id": 4,
        "title": "Records Processed Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(processing_records_total[5m])",
            "legendFormat": "{{source}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}
      },
      {
        "id": 5,
        "title": "Files Processed by Status",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(processing_files_total[5m])",
            "legendFormat": "{{source}} - {{status}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16}
      },
      {
        "id": 6,
        "title": "Upload File Size (avg)",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(file_upload_size_bytes_sum[5m]) / rate(file_upload_size_bytes_count[5m])",
            "legendFormat": "{{source}} - {{file_type}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16}
      },
      {
        "id": 7,
        "title": "Cache Hit Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(cache_hits_total[5m]) / (rate(cache_hits_total[5m]) + rate(cache_misses_total[5m]))",
            "legendFormat": "{{cache_type}}"
          }
        ],
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 24}
      }
    ],
    "refresh": "10s",
    "schemaVersion": 27,
    "version": 1
  }
}
